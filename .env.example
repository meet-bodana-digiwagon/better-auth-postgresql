# Server
PORT=3000
NODE_ENV=development

# Client
CLIENT_ORIGIN_URL="http://localhost:5173"

# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/auth_db?schema=public"

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-random-string-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Logging (optional)
LOG_LEVEL=info
